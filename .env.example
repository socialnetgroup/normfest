# Supabase (EU project — normfest-staging / normfest-prod, §3.1)
# Anon key + URL are exposed to the browser (NEXT_PUBLIC_*); RLS enforces access.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — used for admin/import/ingest jobs (lib/supabase/admin.ts).
# Never expose to the browser (§3.2.2).
SUPABASE_SERVICE_ROLE_KEY=

# ── Later milestones (not required for M0, keep unset until then) ────────
# Anthropic API key, server-only (M5+ enrichment, M7 assistant) — §3.3.
# ANTHROPIC_API_KEY=

# Google Places API key, server-only (M5 enrichment) — §9, §14.3.
# GOOGLE_PLACES_API_KEY=
